<%- include('partials/header') %>

<main class="container">
  
  <!-- Success / Error alerts -->
  <% if (typeof success !== 'undefined' && success) { %>
    <div class="alert alert-success">
      <i class="fa-solid fa-circle-check"></i> <%= success %>
    </div>
  <% } %>
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="alert alert-danger">
      <i class="fa-solid fa-circle-exclamation"></i> <%= error %>
    </div>
  <% } %>

  <!-- Dashboard Top Navigation Bar -->
  <div class="dashboard-header">
    <div>
      <h1 style="font-weight: 800; letter-spacing: -0.02em;">Admin Control Center</h1>
      <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 4px;">Welcome back, <strong><%= user.username %></strong>. You have administrative privileges.</p>
    </div>
    <div>
      <% if (mode === 'list') { %>
        <a href="/admin/new" class="btn btn-primary">
          <i class="fa-solid fa-plus"></i> Write Article
        </a>
      <% } else { %>
        <a href="/admin" class="btn btn-secondary">
          <i class="fa-solid fa-arrow-left"></i> Back to Dashboard
        </a>
      <% } %>
    </div>
  </div>

  <% if (mode === 'list') { %>
    <!-- ==============================================
         1. DASHBOARD LIST MODE
         ============================================== -->
    
    <!-- Post Statistics Grid -->
    <section class="dashboard-stats">
      <div class="stat-card">
        <div class="stat-icon"><i class="fa-solid fa-newspaper"></i></div>
        <div class="stat-info">
          <h5>Total Articles</h5>
          <p><%= posts.length %></p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fa-solid fa-tags"></i></div>
        <div class="stat-info">
          <h5>Active Categories</h5>
          <p>
            <% 
              const catSet = new Set(posts.map(p => p.category)); 
            %>
            <%= catSet.size %>
          </p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon"><i class="fa-solid fa-shield-halved"></i></div>
        <div class="stat-info">
          <h5>Session Status</h5>
          <p style="font-size: 1.1rem; color: #34d399; font-weight: 700; margin-top: 8px;">
            <i class="fa-solid fa-circle" style="font-size: 0.7rem; margin-right: 6px;"></i> Secure Active
          </p>
        </div>
      </div>
    </section>

    <!-- Post Management Table -->
    <section class="dashboard-table-card">
      <div style="padding: 24px; border-bottom: 1px solid rgba(255, 255, 255, 0.04); display: flex; justify-content: space-between; align-items: center;">
        <h3 style="font-size: 1.15rem; font-weight: 700;">Manage Blog Publications</h3>
        <span style="font-size: 0.8rem; color: var(--text-muted);"><%= posts.length %> articles indexed</span>
      </div>

      <div class="table-responsive">
        <table class="db-table">
          <thead>
            <tr>
              <th>Title & Slug</th>
              <th>Category</th>
              <th>Author</th>
              <th>Read Time</th>
              <th>Date Created</th>
              <th style="text-align: right;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (posts.length > 0) { %>
              <% posts.forEach(post => { %>
                <tr>
                  <td>
                    <span class="db-title-cell"><%= post.title %></span>
                    <span class="db-title-slug">/<%= post.slug %></span>
                  </td>
                  <td>
                    <span class="badge badge-<%= post.category.toLowerCase() %>"><%= post.category %></span>
                  </td>
                  <td>
                    <span style="font-weight: 500; font-size: 0.9rem;"><%= post.author %></span>
                  </td>
                  <td>
                    <span style="font-size: 0.9rem; color: var(--text-secondary);"><%= post.read_time %> min</span>
                  </td>
                  <td>
                    <span style="font-size: 0.85rem; color: var(--text-muted);">
                      <%= new Date(post.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                    </span>
                  </td>
                  <td style="text-align: right;">
                    <div class="db-actions" style="justify-content: flex-end;">
                      <a href="/blog/<%= post.slug %>" class="action-btn" target="_blank" title="View Public Article">
                        <i class="fa-solid fa-eye"></i>
                      </a>
                      <a href="/admin/edit/<%= post.id %>" class="action-btn action-edit" title="Edit Article">
                        <i class="fa-solid fa-pen-to-square"></i>
                      </a>
                      <form action="/admin/delete/<%= post.id %>" method="POST" style="display: inline;" 
                            onsubmit="return confirm('Are you absolutely sure you want to delete this post? This action is irreversible.');">
                        <button type="submit" class="action-btn action-delete" title="Delete Article">
                          <i class="fa-solid fa-trash-can"></i>
                        </button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }) %>
            <% } else { %>
              <tr>
                <td colspan="6" style="text-align: center; padding: 40px; color: var(--text-secondary);">
                  <i class="fa-regular fa-folder-open" style="font-size: 2rem; margin-bottom: 12px; display: block; color: var(--text-muted);"></i>
                  No posts published yet. Click "Write Article" to publish your first post!
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </section>

  <% } else if (mode === 'create' || mode === 'edit') { %>
    <!-- ==============================================
         2. EDITOR CREATE/EDIT MODE
         ============================================== -->
    
    <% 
      const isEdit = mode === 'edit';
      const formAction = isEdit ? `/admin/edit/${postToEdit.id}` : '/admin/new';
      const activePost = postToEdit || {};
    %>

    <section class="editor-container">
      
      <!-- Editor Input Form -->
      <div class="editor-form-card">
        <h3 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 24px; display: flex; align-items: center; gap: 8px;">
          <i class="fa-solid fa-pen-nib" style="color: var(--accent-orange);"></i>
          <%= isEdit ? 'Modify Existing Article' : 'Draft New Article' %>
        </h3>

        <form action="<%= formAction %>" method="POST">
          
          <div class="form-group">
            <label for="title" class="form-label">Article Title *</label>
            <input type="text" id="title" name="title" class="form-input" 
                   placeholder="e.g. Setting Up KVM VPS from Scratch" 
                   value="<%= activePost.title || '' %>" required autocomplete="off">
          </div>

          <div class="form-group">
            <label for="slug" class="form-label">URL Slug (Auto-generated)</label>
            <input type="text" id="slug" name="slug" class="form-input" 
                   placeholder="e.g. setting-up-kvm-vps-from-scratch" 
                   value="<%= activePost.slug || '' %>" autocomplete="off">
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="category" class="form-label">Category *</label>
              <select id="category" name="category" class="form-input" style="cursor: pointer;" required>
                <% 
                  const categoriesOptions = ['Tutorials', 'Hardware', 'Network', 'Announcements'];
                  const currentCat = activePost.category || 'Tutorials';
                %>
                <% categoriesOptions.forEach(opt => { %>
                  <option value="<%= opt %>" <%= currentCat === opt ? 'selected' : '' %>><%= opt %></option>
                <% }) %>
              </select>
            </div>
            
            <div class="form-group">
              <label for="author" class="form-label">Author *</label>
              <input type="text" id="author" name="author" class="form-input" 
                     placeholder="e.g. RyzenNodes Tech Team" 
                     value="<%= activePost.author || user.username %>" required autocomplete="name">
            </div>
          </div>

          <div class="form-row">
            <div class="form-group">
              <label for="cover_image" class="form-label">Cover Image URL</label>
              <input type="url" id="cover_image" name="cover_image" class="form-input" 
                     placeholder="https://images.unsplash.com/... or blank" 
                     value="<%= activePost.cover_image || '' %>">
            </div>

            <div class="form-group">
              <label for="read_time" class="form-label">
                Read Time (Minutes) 
                <span id="auto-read-time" style="color: var(--text-muted); font-weight: normal; font-size: 0.8rem;"></span>
              </label>
              <input type="number" id="read_time" name="read_time" class="form-input" 
                     placeholder="e.g. 5" min="1" 
                     value="<%= activePost.read_time || '' %>">
            </div>
          </div>

          <div class="form-group" style="margin-bottom: 0;">
            <label for="content" class="form-label">Markdown Article Content *</label>
            <textarea id="content" name="content" class="form-input" 
                      placeholder="Write your article in Markdown syntax here..." required><%= activePost.content || '' %></textarea>
          </div>

          <div class="editor-footer">
            <a href="/admin" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">
              <i class="fa-solid fa-cloud-arrow-up" style="margin-right: 6px;"></i>
              <%= isEdit ? 'Apply & Save Edits' : 'Publish Article' %>
            </button>
          </div>
        </form>
      </div>

      <!-- Live Markdown Preview (SaaS look) -->
      <div class="editor-preview-card">
        <h3 style="font-size: 1.2rem; font-weight: 700; margin-bottom: 24px; display: flex; align-items: center; gap: 8px;">
          <i class="fa-solid fa-laptop-code" style="color: var(--accent-orange);"></i>
          Live Article Preview
        </h3>
        
        <div class="editor-preview-content post-content-body" id="preview-body">
          <p class="text-muted">Your rendered article will appear here...</p>
        </div>
      </div>

    </section>

  <% } %>

</main>

<%- include('partials/footer') %>
